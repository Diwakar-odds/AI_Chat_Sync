{
  "name": "contextgap",
  "displayName": "ContextGap",
  "description": "Global AI Chat Sync Engine",
  "version": "0.0.3",
  "publisher": "Diwakar-odds",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Diwakar-odds/AI_Chat_Sync.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextgap.push",
        "title": "ContextGap: Push State"
      },
      {
        "command": "contextgap.pull",
        "title": "ContextGap: Pull State"
      },
      {
        "command": "contextgap.syncNow",
        "title": "ContextGap: Sync Now"
      },
      {
        "command": "contextgap.toggleAutoSync",
        "title": "ContextGap: Toggle Auto-Sync"
      }
    ],
    "configuration": {
      "title": "ContextGap",
      "properties": {
        "contextgap.storageMethod": {
          "type": "string",
          "enum": ["github", "custom_server"],
          "default": "github",
          "description": "Choose the backend storage method."
        },
        "contextgap.customServerUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of your custom self-hosted ContextGap server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "octokit": "^4.0.2"
  }
}
